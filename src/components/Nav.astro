---
const { pathname } = Astro.url;

const links = [
  { href: '/',         label: 'Home' },
  { href: '/book',     label: 'The Money Sham' },
  { href: '/policies', label: '7 Policies' },
  { href: '/videos',   label: 'Videos' },
  { href: '/glossary', label: 'Economic Jargon' },
  { href: '/myths',    label: 'Myths & Fact Check' },
  { href: '/mmtuk',    label: 'MMTUK' },
  { href: '/contact',  label: 'Contact' },
];

const isCurrent = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="border-b border-[color:var(--color-rule)] bg-[color:var(--color-paper)]">
  <div class="wrap">
    <!-- Masthead -->
    <div class="flex flex-col gap-4 pt-6 sm:flex-row sm:items-end sm:justify-between sm:pt-8">
      <a href="/" class="group block no-underline">
        <span class="display block text-[1.75rem] font-semibold leading-[0.95] tracking-[-0.02em] text-[color:var(--color-ink)] sm:text-[2.15rem]">
          Real Resource Economics
        </span>
        <span class="mt-2 block text-sm tracking-wide text-[color:var(--color-ink-soft)]">
          Home to <span class="text-[color:var(--color-accent-deep)]">The Money Sham</span>
        </span>
      </a>
      <span class="label hidden sm:block sm:pb-1.5">Stephen&nbsp;Laughton</span>
    </div>

    <!-- Desktop nav -->
    <nav class="mt-5 hidden border-t border-[color:var(--color-rule)] sm:block" aria-label="Main">
      <ul class="-mb-px flex flex-wrap items-stretch gap-x-7 text-[0.9rem]">
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              aria-current={isCurrent(href) ? 'page' : undefined}
              class:list={[
                'navlink relative block py-3.5',
                isCurrent(href) && 'border-b-2 border-[color:var(--color-accent)]',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Mobile nav (no JS) -->
    <details class="group mt-4 border-t border-[color:var(--color-rule)] sm:hidden">
      <summary
        class="flex cursor-pointer list-none items-center justify-between py-3 text-sm font-semibold text-[color:var(--color-ink)]"
      >
        <span class="label !text-[color:var(--color-ink-soft)]">Sections</span>
        <span class="text-[color:var(--color-accent-deep)]">
          <span class="group-open:hidden">＋</span>
          <span class="hidden group-open:inline">－</span>
        </span>
      </summary>
      <nav class="pb-3" aria-label="Mobile">
        <ul class="flex flex-col">
          {links.map(({ href, label }) => (
            <li class="border-t border-[color:var(--color-rule)]/60">
              <a
                href={href}
                aria-current={isCurrent(href) ? 'page' : undefined}
                class:list={[
                  'navlink block py-2.5 text-base',
                  isCurrent(href) && 'pl-3 border-l-2 border-[color:var(--color-accent)]',
                ]}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </details>
  </div>
</header>
