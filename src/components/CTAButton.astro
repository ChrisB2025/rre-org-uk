---
interface Props {
  href: string;
  external?: boolean;
  variant?: 'solid' | 'outline';
}

const { href, external = false, variant = 'solid' } = Astro.props;

const base =
  'group inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold no-underline tracking-wide transition-all duration-150';
const styles = {
  solid:
    'bg-[color:var(--color-ink)] text-[color:var(--color-paper)] hover:bg-[color:var(--color-accent-deep)]',
  outline:
    'border border-[color:var(--color-ink)] text-[color:var(--color-ink)] hover:border-[color:var(--color-accent-deep)] hover:text-[color:var(--color-accent-deep)]',
};

const externalAttrs = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<a href={href} class:list={[base, styles[variant]]} {...externalAttrs}>
  <slot />
  <span aria-hidden="true" class="transition-transform duration-150 group-hover:translate-x-0.5">→</span>
</a>
