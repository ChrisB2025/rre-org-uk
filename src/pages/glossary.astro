---
import { marked } from 'marked';
import BaseLayout from '../layouts/BaseLayout.astro';
import glossaryData from '../data/glossary.json';

interface Entry {
  term: string;
  definition: string;
  todo: boolean;
}

marked.setOptions({ gfm: true });

const entries: Entry[] = glossaryData.entries;
const note: string = glossaryData.note;
const overviewTitle: string = glossaryData.overviewTitle;
const overviewHtml: string = marked.parse(glossaryData.overview) as string;

const groupLetter = (term: string) =>
  (term.match(/[A-Za-z]/)?.[0] ?? '#').toUpperCase();

const grouped = entries.reduce<Record<string, Entry[]>>((acc, entry) => {
  const letter = groupLetter(entry.term);
  (acc[letter] ||= []).push(entry);
  return acc;
}, {});

const letters = Object.keys(grouped).sort();
---

<BaseLayout
  title="Economic Jargon – Glossary"
  description="A plain-language glossary of economics and Modern Monetary Theory terms, from The Money Sham by Stephen Laughton."
>
  <p class="label">Reference</p>
  <h1 class="mt-3">Economic Jargon</h1>
  <p class="lede mt-6">{note}</p>

  <!-- Sticky A–Z index -->
  <nav
    aria-label="Jump to section"
    class="sticky top-0 z-10 -mx-6 mt-10 border-y border-[color:var(--color-rule)] bg-[color:var(--color-paper)]/90 px-6 py-2.5 backdrop-blur sm:-mx-10 sm:px-10 lg:-mx-16 lg:px-16"
  >
    <ul class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm tabular-nums">
      <li>
        <a href="#overview" class="navlink font-semibold">Overview</a>
      </li>
      <li aria-hidden="true" class="text-[color:var(--color-rule)]">/</li>
      {letters.map((letter) => (
        <li>
          <a href={`#letter-${letter}`} class="navlink font-semibold hover:text-[color:var(--color-accent-deep)]">
            {letter}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <section id="overview" class="prose-glossary mt-12 scroll-mt-16">
    <p class="label">Introduction</p>
    <h2 class="!mt-2">{overviewTitle}</h2>
    <div set:html={overviewHtml} />
  </section>

  <div class="mt-16 space-y-16">
    {letters.map((letter) => (
      <section id={`letter-${letter}`} class="scroll-mt-16">
        <h2 class="display !mt-0 flex items-baseline gap-4 border-b-2 border-[color:var(--color-ink)] pb-2 text-[2.5rem] font-semibold text-[color:var(--color-accent)]">
          {letter}
          <span class="text-sm font-normal tracking-wide text-[color:var(--color-ink-soft)]">
            {grouped[letter].length} {grouped[letter].length === 1 ? 'entry' : 'entries'}
          </span>
        </h2>
        <dl class="mt-7 space-y-8">
          {grouped[letter].map((entry) => (
            <div>
              <dt class="display text-[1.2rem] font-semibold text-[color:var(--color-ink)]">
                {entry.term}
              </dt>
              <dd class:list={[
                'prose-glossary mt-1.5',
                entry.todo && 'italic text-[color:var(--color-ink-soft)]/70',
              ]} set:html={marked.parse(entry.definition)} />
            </div>
          ))}
        </dl>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  /* Prose styling for Markdown-rendered glossary content. */
  .prose-glossary :global(p) {
    margin-top: 0.75rem;
    max-width: 44rem;
  }
  .prose-glossary :global(p:first-child) { margin-top: 0; }
  .prose-glossary :global(ul),
  .prose-glossary :global(ol) {
    margin-top: 0.75rem;
    max-width: 44rem;
    padding-left: 1.4rem;
    list-style-position: outside;
  }
  .prose-glossary :global(ul) { list-style-type: disc; }
  .prose-glossary :global(ol) { list-style-type: decimal; }
  .prose-glossary :global(li) { margin-top: 0.35rem; }
  .prose-glossary :global(li > ul),
  .prose-glossary :global(li > ol) { margin-top: 0.35rem; }
  .prose-glossary :global(strong) { color: var(--color-ink); font-weight: 600; }
  .prose-glossary :global(h4) {
    font-family: var(--font-display);
    margin-top: 1.4rem;
    margin-bottom: 0.25rem;
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-ink);
  }
  .prose-glossary :global(table) {
    margin-top: 1rem;
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    display: block;
    overflow-x: auto;
  }
  .prose-glossary :global(th),
  .prose-glossary :global(td) {
    border: 1px solid var(--color-rule);
    padding: 0.45rem 0.7rem;
    text-align: left;
    vertical-align: top;
  }
  .prose-glossary :global(th) {
    background: var(--color-paper-2);
    font-weight: 600;
    color: var(--color-ink);
  }
</style>
