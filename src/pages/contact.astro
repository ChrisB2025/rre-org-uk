---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';

const params = Astro.url.searchParams;
const status = params.get('sent') === '1' ? 'sent' : params.get('error') === '1' ? 'error' : null;

const field =
  'mt-2 w-full border border-[color:var(--color-rule)] bg-white/70 px-3.5 py-2.5 text-[color:var(--color-ink)] outline-none transition-colors focus:border-[color:var(--color-accent)]';
---

<BaseLayout title="Contact" description="Get in touch with Stephen Laughton.">
  <p class="label">Get in Touch</p>
  <h1 class="mt-3">Contact</h1>

  <div class="mt-10 grid gap-x-12 gap-y-8 sm:grid-cols-[10rem_1fr]">
    <p class="label sm:pt-1.5">Send a Message</p>

    <div class="!mt-0 max-w-[34rem]">
      <p class="lede !mt-0 mb-8">
        Have a question or comment about <em>The Money Sham</em> or Real Resource
        Economics? Send a message below.
      </p>

      {status === 'sent' && (
        <p data-banner="sent" class="mb-8 border-l-2 border-[color:var(--color-accent)] bg-[color:var(--color-paper-2)] px-4 py-3 text-sm text-[color:var(--color-ink)]">
          Thank you — your message has been sent. Steve will get back to you.
        </p>
      )}
      {status === 'error' && (
        <p data-banner="error" class="mb-8 border-l-2 border-[color:var(--color-accent)] bg-[color:var(--color-paper-2)] px-4 py-3 text-sm text-[color:var(--color-ink)]">
          Sorry, something went wrong and your message wasn’t sent. Please try again.
        </p>
      )}

      <form method="POST" action="/api/contact" class="space-y-6" data-contact-form>
        <div>
          <label for="name" class="label !text-[color:var(--color-ink-soft)]">Name</label>
          <input id="name" name="name" type="text" required autocomplete="name" class={field} />
        </div>
        <div>
          <label for="email" class="label !text-[color:var(--color-ink-soft)]">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" class={field} />
        </div>
        <div>
          <label for="message" class="label !text-[color:var(--color-ink-soft)]">Message</label>
          <textarea id="message" name="message" rows="6" required class={field}></textarea>
        </div>

        <!-- Honeypot: hidden from humans; bots fill it -->
        <div aria-hidden="true" class="hidden">
          <label>Company<input name="company" type="text" tabindex="-1" autocomplete="off" /></label>
        </div>
        <input type="hidden" name="ts" value="" data-ts />

        <div class="flex flex-wrap items-center gap-4 pt-1">
          <button
            type="submit"
            class="group inline-flex items-center gap-2 bg-[color:var(--color-ink)] px-6 py-3 text-sm font-semibold tracking-wide text-[color:var(--color-paper)] transition-colors duration-150 hover:bg-[color:var(--color-accent-deep)]"
          >
            Send message
            <span aria-hidden="true" class="transition-transform duration-150 group-hover:translate-x-0.5">→</span>
          </button>
          <p data-form-status role="status" aria-live="polite" class="text-sm text-[color:var(--color-ink-soft)]"></p>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.querySelector('[data-contact-form]');
  if (form instanceof HTMLFormElement) {
    const tsField = form.querySelector('[data-ts]');
    if (tsField instanceof HTMLInputElement) tsField.value = String(Date.now());

    const statusEl = form.querySelector('[data-form-status]');
    const setStatus = (msg: string) => {
      if (statusEl) statusEl.textContent = msg;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = form.querySelector('button[type="submit"]');
      if (button instanceof HTMLButtonElement) button.disabled = true;
      setStatus('Sending…');
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await res.json().catch(() => ({ ok: res.ok }));
        if (res.ok && data.ok) {
          form.reset();
          setStatus('Thank you — your message has been sent.');
        } else {
          setStatus('Sorry, that didn’t send. Please check your details and try again.');
        }
      } catch {
        setStatus('Sorry, that didn’t send. Please try again.');
      } finally {
        if (button instanceof HTMLButtonElement) button.disabled = false;
      }
    });
  }
</script>
