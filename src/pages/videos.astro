---
import BaseLayout from '../layouts/BaseLayout.astro';

const videos = [
  {
    title: 'The Money Sham — Stephen Laughton',
    label: 'Publisher interview',
    description:
      'Carlos García Hernández of Lola Books in conversation with the author about The Money Sham.',
    href: 'https://www.linkedin.com/posts/carlos-garc%C3%ADa-hern%C3%A1ndez-7a0384175_the-money-sham-stephen-laughton-activity-7464298471353733120-yjK6',
    source: 'LinkedIn',
  },
];
---

<BaseLayout
  title="Videos"
  description="Talks, interviews and explainers on Real Resource Economics and the ideas behind The Money Sham by Stephen Laughton."
>
  <p class="label">Watch</p>
  <h1 class="mt-3">Videos</h1>

  <p class="lede mt-8">
    Talks, interviews and explainers on Real Resource Economics and the ideas
    behind <em>The Money Sham</em>.
  </p>

  <ul class="mt-12 space-y-6">
    {videos.map((v) => (
      <li>
        <a
          href={v.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group block border-t border-[color:var(--color-rule)] pt-6 no-underline"
        >
          <p class="label !text-[color:var(--color-ink-soft)]">{v.label}</p>
          <h2 class="mt-2 text-2xl text-[color:var(--color-ink)] group-hover:text-[color:var(--color-accent-deep)]">
            {v.title}
            <span aria-hidden="true" class="inline-block transition-transform duration-150 group-hover:translate-x-0.5">→</span>
          </h2>
          <p class="mt-2 max-w-[42rem] text-[color:var(--color-ink-soft)]">{v.description}</p>
          <p class="mt-2 text-sm text-[color:var(--color-ink-soft)]">Watch on {v.source}</p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
