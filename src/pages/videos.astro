---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Video {
  youtubeId: string;
  label: string;
  title: string;
  description: string;
}

const videos: Video[] = [
  {
    youtubeId: 'fZxDgcUtrhw',
    label: 'Publisher interview',
    title: 'The Money Sham: in conversation with Lola Books',
    description:
      'Stephen Laughton talks with his publisher, Carlos García Hernández of Lola Books, about The Money Sham: why a misconception about money traps both left and right, and what Real Resource Economics makes possible.',
  },
];

const watchUrl = (id: string) => `https://www.youtube.com/watch?v=${id}`;
const thumbMax = (id: string) => `https://img.youtube.com/vi/${id}/maxresdefault.jpg`;
const thumbHq = (id: string) => `https://img.youtube.com/vi/${id}/hqdefault.jpg`;
---

<BaseLayout
  title="Videos"
  description="Talks, interviews and explainers on Real Resource Economics and the ideas behind The Money Sham by Stephen Laughton."
>
  <p class="label">Watch</p>
  <h1 class="mt-3">Videos</h1>

  <p class="lede mt-8 max-w-[44rem]">
    Talks, interviews and explainers on Real Resource Economics and the ideas
    behind <em>The Money Sham</em>.
  </p>

  <ul class="mt-12 grid gap-10 sm:grid-cols-2">
    {videos.map((v) => (
      <li>
        <a
          href={watchUrl(v.youtubeId)}
          target="_blank"
          rel="noopener noreferrer"
          class="group block no-underline"
          aria-label={`Watch on YouTube: ${v.title}`}
        >
          <div class="relative aspect-video overflow-hidden border border-[color:var(--color-rule)] bg-[color:var(--color-paper-2)]">
            <img
              src={thumbMax(v.youtubeId)}
              data-fallback={thumbHq(v.youtubeId)}
              onerror="if(this.dataset.fallback){this.src=this.dataset.fallback;this.dataset.fallback='';}"
              alt={`Thumbnail for ${v.title}`}
              width="1280"
              height="720"
              loading="lazy"
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
            />
            <!-- Play button overlay -->
            <span class="absolute inset-0 flex items-center justify-center">
              <span class="flex h-16 w-16 items-center justify-center rounded-full bg-[color:var(--color-ink)]/80 text-[color:var(--color-paper)] shadow-lg transition-all duration-200 group-hover:scale-110 group-hover:bg-[color:var(--color-accent-deep)]">
                <svg viewBox="0 0 24 24" fill="currentColor" class="ml-1 h-7 w-7" aria-hidden="true">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </span>
            </span>
          </div>

          <p class="label !text-[color:var(--color-ink-soft)] mt-4">{v.label}</p>
          <h2 class="mt-1.5 text-xl text-[color:var(--color-ink)] group-hover:text-[color:var(--color-accent-deep)]">
            {v.title}
          </h2>
          <p class="mt-2 text-[color:var(--color-ink-soft)]">{v.description}</p>
          <p class="mt-2 text-sm text-[color:var(--color-ink-soft)]">
            Watch on YouTube
            <span aria-hidden="true" class="inline-block transition-transform duration-150 group-hover:translate-x-0.5">→</span>
          </p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
