---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const brand = 'Real Resource Economics';

const {
  title = `${brand}: Home to The Money Sham`,
  description = 'Real Resource Economics, home to The Money Sham by Stephen Laughton. How a misconception about money shackles UK politics, and what becomes possible once we see past it.',
} = Astro.props;

const fullTitle = title.includes(brand) ? title : `${title} | ${brand}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#f7f4ec" />
    <!-- Umami analytics (privacy-friendly, cookieless). data-domains keeps
         dev/preview traffic out of the stats. -->
    <script
      is:inline
      defer
      src="https://umami-production-7481.up.railway.app/script.js"
      data-website-id="5b7072a2-b13a-4614-85b6-51a52126ea3b"
      data-domains="rre.org.uk,www.rre.org.uk"
    ></script>
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-3 focus:z-50 focus:bg-[color:var(--color-ink)] focus:px-3 focus:py-1.5 focus:text-sm focus:text-[color:var(--color-paper)]">
      Skip to content
    </a>
    <Nav />
    <main id="main" class="wrap py-14 sm:py-20">
      <slot />
    </main>
    <Footer />
  </body>
</html>
