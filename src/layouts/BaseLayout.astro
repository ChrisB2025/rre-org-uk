---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const brand = 'The Money Sham';

const {
  title = `${brand}: Host to Real Resource Economics`,
  description = 'The Money Sham by Stephen Laughton, host to Real Resource Economics. How a misconception about money shackles UK politics, and what becomes possible once we see past it.',
} = Astro.props;

const fullTitle = title.includes(brand) ? title : `${title} | ${brand}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#f7f4ec" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-3 focus:z-50 focus:bg-[color:var(--color-ink)] focus:px-3 focus:py-1.5 focus:text-sm focus:text-[color:var(--color-paper)]">
      Skip to content
    </a>
    <Nav />
    <main id="main" class="wrap py-14 sm:py-20">
      <slot />
    </main>
    <Footer />
  </body>
</html>
